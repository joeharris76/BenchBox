include README.md
include CHANGELOG.md
include LICENSE
include pyproject.toml
include MANIFEST.in

recursive-include benchbox *.py *.sql *.yaml *.json *.jinja2 *.md *.csv
prune benchbox/platforms/clickhouse
prune benchbox/platforms/bigquery
prune benchbox/tpchavoc
prune benchbox/primitives
prune benchbox/tpcdi

# Include _sources/ for sdist (patches, EULAs, compilation infra, templates)
# Note: Runtime templates are ALSO bundled inside benchbox/_binaries/*/templates/
# for wheel installs where _sources/ is not available
include _sources/README.md
include _sources/tpc-h/EULA.txt
include _sources/tpc-h/PATCHES.md
include _sources/tpc-h/stdout-support.patch
include _sources/tpc-ds/EULA.txt
include _sources/tpc-ds/PATCHES.md
include _sources/tpc-ds/stdout-support.patch
recursive-include _sources/compilation *
recursive-include _sources/tpc-ds/query_templates *.tpl *.lst
recursive-include _sources/tpc-ds/query_variants *.tpl
recursive-include _sources/tpc-h/dbgen/queries *.sql
recursive-include _sources/tpc-h/dbgen/variants *.sql

# Include pre-compiled TPC binaries (required for data generation)
# These are platform-specific executables for TPC-H and TPC-DS benchmarks
# Binaries are included inside the benchbox package for proper installation
recursive-include benchbox/_binaries/tpc-h *
recursive-include benchbox/_binaries/tpc-ds *
# Exclude macOS metadata files
global-exclude .DS_Store

prune tests
prune docs
prune examples

global-exclude *.py[cod] __pycache__ *.so *.dylib *.dll *.log
